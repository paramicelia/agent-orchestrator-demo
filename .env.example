# Groq API — required at runtime, optional at import time
# Sign up at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model tiering (override defaults if needed)
GROQ_SMART_MODEL=llama-3.3-70b-versatile
GROQ_LITE_MODEL=llama-3.1-8b-instant

# Memory layer
# Backend selector: "chroma" (default, local) or "pgvector" (Postgres + pgvector).
MEMORY_BACKEND=chroma
MEMORY_DB_PATH=./chroma_db
MEMORY_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Required only when MEMORY_BACKEND=pgvector. Boot Postgres + pgvector with
# `docker compose -f compose.pgvector.yml up -d` and the line below works as-is.
POSTGRES_DSN=postgresql://agent:agent@localhost:5432/agent_demo

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# Observability (optional — leave blank to disable)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agent-orchestrator-demo
LANGCHAIN_TRACING_V2=false
