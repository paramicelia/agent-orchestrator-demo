# Local data
chroma_db/
*.sqlite
*.db
*.log

# Eval — regenerated by `make eval`; the markdown summary is committed,
# the per-turn JSON dump is not (it captures full reply transcripts and
# would bloat the repo on every run).
eval/results.json
eval/_ci_smoke_out/

# LangSmith local traces (never push these — they may leak prompts).
langsmith_traces/

# Tenant secrets (per-tenant API keys, credentials). Drop them in
# tenants/_secrets/ and they stay out of git. The underscore prefix also
# tells backend.tenants.loader to skip the file.
tenants/_secrets/
tenants/_disabled.yaml

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Pytest / mypy / ruff
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Docker
.docker/
